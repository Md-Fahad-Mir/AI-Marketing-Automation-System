# AI provider selection for marketing-text generation.
# Copy this file to ".env" and set the values for the provider you want.
# Switching providers requires editing this file only — no code changes.
#
# AI_PROVIDER: one of mock | openai | gemini | claude
#   - mock (default): deterministic local text, no API key, no network calls.
#   - openai / gemini / claude: calls the real API using the key below.
# If the selected provider's key is missing or its SDK is unavailable, the
# system automatically falls back to the mock provider.

AI_PROVIDER=mock

# --- OpenAI (GPT) ---
# AI_PROVIDER=openai
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini ---
# AI_PROVIDER=gemini
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- Anthropic Claude ---
# AI_PROVIDER=claude
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Image generation (optional) ---
# IMAGE_PROVIDER selects the image provider independently of text.
#   Defaults to AI_PROVIDER when unset. Values: mock | openai | gemini | claude.
#   "claude" has no image API, so it falls back to the mock image provider.
#   OpenAI (DALL-E) and Gemini (Imagen) images are saved under image_storage_dir
#   and served by the app at PUBLIC_BASE_URL/images/<file>.
# IMAGE_PROVIDER=
# OPENAI_IMAGE_MODEL=gpt-image-1     # or gpt-image-1-mini (cheaper); older keys: dall-e-3
# GEMINI_IMAGE_MODEL=imagen-3.0-generate-002
# IMAGE_STORAGE_DIR=generated_images
# Base URL the app is reachable at (used to build image URLs).
# PUBLIC_BASE_URL=http://127.0.0.1:8000
